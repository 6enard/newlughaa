rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Languages collection - read-only for all authenticated users
    match /languages/{languageId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admins should write, handle via Firebase Admin SDK
    }

    // Lessons collection - read-only for all authenticated users
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admins should write, handle via Firebase Admin SDK
    }

    // Lesson content collection - read-only for all authenticated users
    match /lessonContent/{contentId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only admins should write, handle via Firebase Admin SDK
    }

    // User language selections - users can only read and write their own selections
    match /userLanguages/{userLanguageId} {
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'languageId', 'createdAt']);
      allow update, delete: if isAuthenticated() &&
                               resource.data.userId == request.auth.uid;
    }

    // User progress - users can only read and write their own progress
    match /userProgress/{progressId} {
      allow read: if isAuthenticated() &&
                     resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'lessonId', 'completed', 'updatedAt']);
      allow update: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
                       resource.data.userId == request.auth.uid;
    }
  }
}
